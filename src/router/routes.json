[
  {
    "path": "/",
    "name": "home",
    "component": "HomeView",
    "alias": "/home",
    "meta": {
      "title": "首页",
      "keepAlive": true,
      "icon": "home",
      "visible": true,
      "enabled": true,
      "permission": "app:home:view",
      "type": "menu"
    }
  },
  {
    "path": "/demos",
    "name": "demos",
    "component": "RouterView",
    "meta": {
      "title": "示例合集",
      "requiresAuth": false,
      "visible": true,
      "enabled": true,
      "permission": "app:demos:view",
      "type": "directory"
    },
    "children": [
      {
        "path": "",
        "name": "demos-redirect",
        "redirect": "/demos/pinia-demo",
        "component": "RouterView"
      },
      {
        "path": "pinia-demo",
        "name": "pinia-demo",
        "component": "PiniaDemoView",
        "alias": "/pinia-demo",
        "meta": {
          "title": "Pinia 示例",
          "requiresAuth": false,
          "visible": true,
          "enabled": true,
          "permission": "app:demos:pinia",
          "type": "menu"
        }
      },
      {
        "path": "rs232-tcp-demo",
        "name": "rs232-tcp-demo",
        "component": "Rs232TcpView",
        "alias": "/rs232-tcp-demo",
        "meta": {
          "title": "RS232/TCP 通讯",
          "visible": true,
          "enabled": true,
          "permission": "app:demos:rs232-tcp",
          "type": "menu"
        }
      },
      {
        "path": "mqtt-demo",
        "name": "mqtt-demo",
        "component": "MqttDemoView",
        "alias": "/mqtt-demo",
        "meta": {
          "title": "MQTT Demo",
          "visible": true,
          "enabled": true,
          "permission": "app:demos:mqtt",
          "type": "menu"
        }
      },
      {
        "path": "guoxin-rfid-demo",
        "name": "guoxin-rfid-demo",
        "component": "GuoxinRfidView",
        "alias": "/guoxin-rfid-demo",
        "meta": {
          "title": "国芯 RFID 测试",
          "visible": true,
          "enabled": true,
          "permission": "app:demos:guoxin-rfid",
          "type": "menu"
        }
      },
      {
        "path": "pad-lock-demo",
        "name": "pad-lock-demo",
        "component": "PadLockView",
        "alias": "/pad-lock-demo",
        "meta": {
          "title": "PAD 锁控板 测试",
          "visible": true,
          "enabled": true,
          "permission": "app:demos:pad-lock",
          "type": "menu"
        }
      }
    ]
  },
  {
    "path": "/:pathMatch(.*)*",
    "name": "not-found",
    "component": "NotFoundView",
    "meta": {
      "title": "页面不存在",
      "layout": "blank",
      "visible": false,
      "enabled": false
    }
  }
]
